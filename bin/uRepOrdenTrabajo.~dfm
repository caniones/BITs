  object zroqCostoTotal: TZReadOnlyQuery
    Connection = dmConexion.zConnection
    SQL.Strings = (
      'SELECT COALESCE('
      '    (SELECT SUM(odr.costo) '
      '     FROM ordenes_repuestos odr '
      '     WHERE odr.orden_id = :id_orden), '
      '    CAST(0 AS NUMERIC)'
      ') as costo_total;')
    Params = <
      item
        Name = 'id_orden'
      end>
    DataSource = dsOrden
    Left = 48
    Top = 240
    ParamData = <
      item
        Name = 'id_orden'
      end>
