  object zqOrden: TZQuery
    Connection = dmConexion.zConnection
    SQL.Strings = (
      
        'SELECT o.id_orden, o.fecha, c.cliente, c.telefono, c.direccion, ' +
        'o.equipo_id, te.equipo||'#39' - '#39'||m.marca||'#39' - '#39'||eq.modelo||'#39' - '#39'|' +
        '|eq.numero_serie as equipo, eq.observaciones, o.falla, od.estado' +
        '_id, e.estado'
      'FROM ordenes o'#10
      ''
      'INNER JOIN ('#10
      ''
      '    SELECT DISTINCT ON (orden_id) '#10
      ''
      '        orden_id, '#10
      ''
      '        estado_id'#10
      ''
      '    FROM ordenes_detalles'#10
      ''
      
        '    ORDER BY orden_id, fecha DESC, id_orden_detalle DESC) od ON ' +
        'o.id_orden = od.orden_id'#10
      ''
      'INNER JOIN estados e ON e.id_estado = od.estado_id'#10
      ''
      'INNER JOIN equipos eq ON eq.id_equipo = o.equipo_id'#10
      ''
      
        'INNER JOIN tipos_equipos te ON te.id_tipo_equipo = eq.tipo_equip' +
        'o_id'#10
      ''
      'INNER JOIN marcas m ON m.id_marca = eq.marca_id'#10
      ''
      'INNER JOIN clientes c ON c.id_cliente = eq.cliente_id'
      'WHERE o.id_orden = :id_orden')
    Params = <
      item
        Name = 'id_orden'
      end>
    Left = 48
    Top = 72
    ParamData = <
      item
        Name = 'id_orden'
      end>
    object zqOrdenid_orden: TIntegerField
      FieldName = 'id_orden'
    end
    object zqOrdenfecha: TDateTimeField
      FieldName = 'fecha'
    end
    object zqOrdencliente: TStringField
      FieldName = 'cliente'
      Required = True
      Size = 100
    end
    object zqOrdentelefono: TStringField
      FieldName = 'telefono'
    end
    object zqOrdendireccion: TStringField
      FieldName = 'direccion'
      Size = 100
    end
    object zqOrdenequipo_id: TIntegerField
      FieldName = 'equipo_id'
      Required = True
    end
    object zqOrdenequipo: TMemoField
      FieldName = 'equipo'
      ReadOnly = True
      BlobType = ftMemo
    end
    object zqOrdenobservaciones: TStringField
      FieldName = 'observaciones'
      Size = 200
    end
